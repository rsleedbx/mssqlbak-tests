    "query_texts": [
      "INSERT INTO padding_fill (id, filler)\nSELECT n, REPLICATE('P', 200)\nFROM (SELECT TOP(250000) ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n\n      FROM master.dbo.spt_values AS a CROSS JOIN master.dbo.spt_values AS b) x",
      "SELECT N'id', ISNULL(CAST(MIN([id]) AS NVARCHAR(200)), N'__NULL__'), ISNULL(CAST(MAX([id]) AS NVARCHAR(200)), N'__NULL__') FROM [dbo].[padding_fill]\nUNION ALL\nSELECT N'filler', ISNULL(CAST(MIN(RTRIM([filler]) COLLATE Latin1_General_100_BIN2) AS NVARCHAR(4000)), N'__NULL__'), ISNULL(CAST(MAX(RTRIM([filler]) COLLATE Latin1_General_100_BIN2) AS NVARCHAR(4000)), N'__NULL__') FROM [dbo].[padding_fill]"
    ]
