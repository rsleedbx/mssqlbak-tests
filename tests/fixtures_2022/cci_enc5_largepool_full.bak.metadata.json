    "query_texts": [
      "INSERT INTO dbo.cci_char_pool (id, login, code)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 13) AS CHAR(13))\n    END AS login,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1000003 AS VARCHAR(12))), 2), 10) AS CHAR(10))\n    END AS code\nFROM fkr__seed\nWHERE pk < 80000",
      "INSERT INTO fkr__seed SELECT pk + 32768 FROM (SELECT pk FROM fkr__seed) AS _s"
