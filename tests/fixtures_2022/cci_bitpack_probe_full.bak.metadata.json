    "query_texts": [
      "CREATE CLUSTERED COLUMNSTORE INDEX cci_bitpack_probe_cci ON cci_bitpack_probe",
      "INSERT INTO cci_bitpack_probe (pk, mod4000, mod2000, mod1000, mod100)\nSELECT CAST(pk AS BIGINT) AS pk, CAST(pk % 4000 AS INT) AS mod4000, CAST(pk % 2000 AS INT) AS mod2000, CAST(pk % 1000 AS INT) AS mod1000, CAST(pk % 100 AS INT) AS mod100\nFROM fkr__seed\nWHERE pk < 200000",
