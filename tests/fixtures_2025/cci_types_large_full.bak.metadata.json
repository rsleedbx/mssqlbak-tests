    "query_texts": [
      "INSERT INTO cci_char (id, val)\nSELECT TOP 1197\n    n + 6 AS id,\n    REPLICATE(CHAR(65 + ((n - 1) % 26)), 20)       AS val\nFROM (\n    SELECT ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n\n    FROM sys.all_objects a CROSS JOIN sys.all_objects b\n) t"
