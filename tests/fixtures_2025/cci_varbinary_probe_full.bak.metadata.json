      "INSERT INTO cci_varbinary_maxwidth (id, val)\nSELECT TOP 1197\n    n + 6                          AS id,\n    CAST(CAST(n AS VARBINARY(4)) AS VARBINARY(16))            AS val\nFROM (\n    SELECT ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n\n    FROM sys.all_objects a CROSS JOIN sys.all_objects b\n) t"
