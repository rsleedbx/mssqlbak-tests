  "query_store": {
    "enabled": true,
    "query_texts": [
      "INSERT INTO dbo.char_32767_distinct_var (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 1 + (pk % 13)) AS CHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 32767",
      "INSERT INTO dbo.char_32768_distinct_var (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 1 + (pk % 13)) AS CHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 32768",
      "INSERT INTO dbo.char_65536_distinct_var (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 1 + (pk % 13)) AS CHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 65536",
      "INSERT INTO dbo.char_80000_distinct_var (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 1 + (pk % 13)) AS CHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 80000",
      "INSERT INTO dbo.char_80000_fullwidth (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 13) AS CHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 80000",
      "INSERT INTO dbo.char_80000_lowcard_var (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST((pk % 4096) + 1 AS VARCHAR(12))), 2), 1 + (pk % 13)) AS CHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 80000",
      "INSERT INTO dbo.varchar_80000_distinct_var (id, val)\nSELECT\n    pk + 1 AS id,\n    CASE WHEN (pk + 1) % 1000 = 0 THEN NULL\n         ELSE CAST(LEFT(CONVERT(CHAR(32), HASHBYTES('MD5', CAST(pk + 1 AS VARCHAR(12))), 2), 1 + (pk % 13)) AS VARCHAR(13))\n    END AS val\nFROM fkr__seed\nWHERE pk < 80000",
      "INSERT INTO fkr__seed SELECT pk + 32768 FROM (SELECT pk FROM fkr__seed) AS _s"
    ]
